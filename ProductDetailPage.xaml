<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.Pages.ProductDetailPage"
             Title="ProductDetailPage">
    <VerticalStackLayout>

        <Grid RowDefinitions="Auto,*,Auto">

            <!-- ── Back + Cart header ───────────────────────────────── -->
            <Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#F5F0EB" ZIndex="1">
                <ImageButton Grid.Column="0"
                         Source="icon_back.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#EBEBEB"
                         CornerRadius="18"
                         Clicked="OnBackClicked" />
                <ImageButton Grid.Column="2"
                         Source="icon_cart.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#EBEBEB"
                         CornerRadius="18"
                         Clicked="OnCartClicked" />
            </Grid>

            <!-- ── Scrollable content ───────────────────────────────── -->
            <ScrollView Grid.Row="1">
                <StackLayout Spacing="0">

                    <!-- Product Image -->
                    <Image x:Name="ProductImage"
                       HeightRequest="300"
                       Aspect="AspectFill"
                       BackgroundColor="#E0D8D0" />

                    <!-- Details card -->
                    <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 24,24,0,0"
                        Stroke="Transparent"
                        Padding="24,28,24,24">
                        <StackLayout Spacing="16">

                            <!-- Badge -->
                            <Border x:Name="BadgeBorder"
                                StrokeShape="RoundRectangle 8"
                                Stroke="Transparent"
                                Padding="10,5"
                                IsVisible="False"
                                HorizontalOptions="Start">
                                <Label x:Name="BadgeLabel"
                                   TextColor="White"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                            </Border>

                            <!-- Name -->
                            <Label x:Name="ProductName"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A" />

                            <!-- Category pill -->
                            <Border BackgroundColor="#F0EBE5"
                                StrokeShape="RoundRectangle 12"
                                Stroke="Transparent"
                                Padding="12,6"
                                HorizontalOptions="Start">
                                <Label x:Name="CategoryLabel"
                                   FontSize="12"
                                   TextColor="#8B7355" />
                            </Border>

                            <!-- Price -->
                            <Label x:Name="PriceLabel"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#C8683A" />

                            <!-- Divider -->
                            <BoxView HeightRequest="1" BackgroundColor="#F0EBE5" />

                            <!-- Description heading -->
                            <Label Text="Description"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A" />

                            <!-- Description text -->
                            <Label x:Name="DescriptionLabel"
                               FontSize="14"
                               TextColor="#666666"
                               LineHeight="1.5" />

                            <!-- Availability -->
                            <HorizontalStackLayout Spacing="8">
                                <Ellipse x:Name="AvailabilityDot"
                                     WidthRequest="10"
                                     HeightRequest="10"
                                     Fill="#4A7C59"
                                     VerticalOptions="Center" />
                                <Label x:Name="AvailabilityLabel"
                                   Text="In stock"
                                   FontSize="14"
                                   TextColor="#4A7C59"
                                   VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Quantity selector -->
                            <Label Text="Quantity"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A" />

                            <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                                <Border BackgroundColor="#F0EBE5"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent">
                                    <Button Text="−"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        FontSize="20"
                                        BackgroundColor="Transparent"
                                        TextColor="#1A1A1A"
                                        Clicked="OnDecreaseQty" />
                                </Border>
                                <Label x:Name="QtyLabel"
                                   Text="1"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#1A1A1A"
                                   WidthRequest="30"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                                <Border BackgroundColor="#F0EBE5"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent">
                                    <Button Text="+"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        FontSize="20"
                                        BackgroundColor="Transparent"
                                        TextColor="#C8683A"
                                        Clicked="OnIncreaseQty" />
                                </Border>
                            </HorizontalStackLayout>

                        </StackLayout>
                    </Border>
                </StackLayout>
            </ScrollView>

            <!-- ── Add to Cart CTA ──────────────────────────────────── -->
            <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 0"
                Stroke="Transparent"
                Padding="20,12">
                <Button x:Name="AddToCartBtn"
                    Text="Add to cart"
                    BackgroundColor="#C8683A"
                    TextColor="White"
                    FontSize="17"
                    FontAttributes="Bold"
                    HeightRequest="54"
                    CornerRadius="14"
                    Clicked="OnAddToCartClicked" />
            </Border>

        </Grid>
    </VerticalStackLayout>
</ContentPage>