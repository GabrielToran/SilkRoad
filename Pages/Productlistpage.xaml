<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.Pages.Productlistpage"
             Title="Productlistpage">
    <VerticalStackLayout>

        <Grid RowDefinitions="Auto,*">

            <!-- ── Header ───────────────────────────────────────────── -->
            <Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="#F5F0EB">
                <ImageButton Grid.Column="0"
                         Source="icon_back.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#EBEBEB"
                         CornerRadius="18"
                         Clicked="OnBackClicked" />
                <Label Grid.Column="1"
                   x:Name="PageTitleLabel"
                   Text="Bedding"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
                <ImageButton Grid.Column="2"
                         Source="icon_cart.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#EBEBEB"
                         CornerRadius="18"
                         Clicked="OnCartClicked" />
            </Grid>

            <!-- ── Product Grid ─────────────────────────────────────── -->
            <RefreshView Grid.Row="1"
                     x:Name="RefreshControl"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}"
                     RefreshColor="#C8683A">

                <CollectionView x:Name="ProductsCollection"
                            ItemsSource="{Binding Products}"
                            SelectionMode="None"
                            Margin="12,0,12,12">

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>

                    <!-- Empty state -->
                    <CollectionView.EmptyView>
                        <StackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                 Padding="40" Spacing="12">
                            <Image Source="icon_empty.png" WidthRequest="80" HeightRequest="80"
                               Opacity="0.4" />
                            <Label Text="No products found" FontSize="16"
                               TextColor="#9E9E9E" HorizontalOptions="Center" />
                        </StackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                Margin="2"
                                Shadow="{Shadow Brush='#20000000', Offset='0,2', Radius='8'}">
                                <Grid RowDefinitions="180,Auto,Auto,Auto">

                                    <!-- Badge -->
                                    <Border Grid.Row="0"
                                        BackgroundColor="{Binding BadgeColor}"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        Padding="8,4"
                                        Margin="10,10,0,0"
                                        IsVisible="{Binding HasBadge}"
                                        ZIndex="1"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Start">
                                        <Label Text="{Binding Badge}"
                                           TextColor="White"
                                           FontSize="11"
                                           FontAttributes="Bold" />
                                    </Border>

                                    <!-- Product Image -->
                                    <Image Grid.Row="0"
                                       Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       BackgroundColor="#E8E0D8" />

                                    <!-- Product Name -->
                                    <Label Grid.Row="1"
                                       Text="{Binding Name}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#1A1A1A"
                                       Margin="12,10,12,2"
                                       LineBreakMode="TailTruncation" />

                                    <!-- Price -->
                                    <Label Grid.Row="2"
                                       Text="{Binding FormattedPrice}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#C8683A"
                                       Margin="12,0,12,8" />

                                    <!-- Add to Cart Button -->
                                    <Border Grid.Row="3"
                                        BackgroundColor="#FAF6F2"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="#E0D8D0"
                                        Margin="10,0,10,12">
                                        <Button Text="+ Add to cart"
                                            BackgroundColor="Transparent"
                                            TextColor="#1A1A1A"
                                            FontSize="13"
                                            HeightRequest="38"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnAddToCartClicked" />
                                    </Border>

                                </Grid>

                                <!-- Tap entire card to see detail -->
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding .}"
                                                      Tapped="OnProductTapped" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- Loading overlay -->
            <ActivityIndicator Grid.Row="1"
                           x:Name="LoadingIndicator"
                           IsRunning="True"
                           IsVisible="True"
                           Color="#C8683A"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>