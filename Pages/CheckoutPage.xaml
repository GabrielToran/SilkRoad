<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.Pages.CheckoutPage"
             Title="CheckoutPage">
    <VerticalStackLayout>
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- ── Header ───────────────────────────────────────────── -->
            <Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="Auto,*"
              BackgroundColor="#F5F0EB">
                <ImageButton Grid.Column="0"
                         Source="icon_back.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#EBEBEB"
                         CornerRadius="18"
                         Clicked="OnBackClicked" />
                <Label Grid.Column="1"
                   Text="Checkout"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            </Grid>

            <!-- ── Scrollable form ──────────────────────────────────── -->
            <ScrollView Grid.Row="1" Padding="16,0,16,16">
                <StackLayout Spacing="14">

                    <!-- Order summary card -->
                    <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 16"
                        Stroke="Transparent"
                        Padding="18"
                        Shadow="{Shadow Brush='#18000000', Offset='0,2', Radius='6'}">
                        <StackLayout Spacing="12">
                            <Label Text="Order summary"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A" />

                            <CollectionView x:Name="OrderItemsList" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="14"
                                               TextColor="#444444" />
                                            <Label Grid.Column="1"
                                               Text="{Binding FormattedPrice}"
                                               FontSize="14"
                                               TextColor="#1A1A1A"
                                               FontAttributes="Bold"
                                               HorizontalOptions="End" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <BoxView HeightRequest="1" BackgroundColor="#F0EBE5" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Total"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#1A1A1A" />
                                <Label Grid.Column="1" x:Name="TotalLabel"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#C8683A"
                                   HorizontalOptions="End" />
                            </Grid>
                        </StackLayout>
                    </Border>

                    <!-- Payment method card -->
                    <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 16"
                        Stroke="Transparent"
                        Padding="18"
                        Shadow="{Shadow Brush='#18000000', Offset='0,2', Radius='6'}">
                        <StackLayout Spacing="14">
                            <Label Text="Payment method"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A" />

                            <!-- Method tabs -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                <Border x:Name="CreditCardTab"
                                    Grid.Column="0"
                                    BackgroundColor="#FDF4EF"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#C8683A"
                                    StrokeThickness="1.5"
                                    Padding="10,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSelectCreditCard" />
                                    </Border.GestureRecognizers>
                                    <StackLayout Spacing="4" HorizontalOptions="Center">
                                        <Image Source="icon_creditcard.png"
                                           WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center" />
                                        <Label Text="Credit card"
                                           FontSize="11"
                                           TextColor="#C8683A"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" />
                                    </StackLayout>
                                </Border>
                                <Border x:Name="PayPalTab"
                                    Grid.Column="1"
                                    BackgroundColor="#F8F8F8"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0"
                                    Padding="10,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSelectPayPal" />
                                    </Border.GestureRecognizers>
                                    <StackLayout Spacing="4" HorizontalOptions="Center">
                                        <Image Source="icon_paypal.png"
                                           WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center" />
                                        <Label Text="PayPal"
                                           FontSize="11"
                                           TextColor="#666666"
                                           HorizontalOptions="Center" />
                                    </StackLayout>
                                </Border>
                                <Border x:Name="CashTab"
                                    Grid.Column="2"
                                    BackgroundColor="#F8F8F8"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0"
                                    Padding="10,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSelectCash" />
                                    </Border.GestureRecognizers>
                                    <StackLayout Spacing="4" HorizontalOptions="Center">
                                        <Image Source="icon_cash.png"
                                           WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center" />
                                        <Label Text="Cash on delivery"
                                           FontSize="11"
                                           TextColor="#666666"
                                           HorizontalTextAlignment="Center"
                                           HorizontalOptions="Center" />
                                    </StackLayout>
                                </Border>
                            </Grid>

                            <!-- Credit Card fields (shown only when Credit Card selected) -->
                            <StackLayout x:Name="CardFields" Spacing="12">

                                <Label Text="Cardholder name"
                                   FontSize="13" TextColor="#666666" />
                                <Border BackgroundColor="#F8F6F3"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="#E0D8D0">
                                    <Entry x:Name="CardholderEntry"
                                       Placeholder="Full name on card"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A1A"
                                       FontSize="15"
                                       BackgroundColor="Transparent"
                                       Margin="4,0" />
                                </Border>

                                <Label Text="Card number"
                                   FontSize="13" TextColor="#666666" />
                                <Border BackgroundColor="#F8F6F3"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="#E0D8D0">
                                    <Entry x:Name="CardNumberEntry"
                                       Placeholder="•••• •••• •••• ••••"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A1A"
                                       FontSize="15"
                                       Keyboard="Numeric"
                                       MaxLength="19"
                                       BackgroundColor="Transparent"
                                       Margin="4,0" />
                                </Border>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <StackLayout Grid.Column="0" Spacing="6">
                                        <Label Text="Expiry"
                                           FontSize="13" TextColor="#666666" />
                                        <Border BackgroundColor="#F8F6F3"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="#E0D8D0">
                                            <Entry x:Name="ExpiryEntry"
                                               Placeholder="MM / YY"
                                               PlaceholderColor="#BBBBBB"
                                               TextColor="#1A1A1A"
                                               FontSize="15"
                                               Keyboard="Numeric"
                                               MaxLength="5"
                                               BackgroundColor="Transparent"
                                               Margin="4,0" />
                                        </Border>
                                    </StackLayout>
                                    <StackLayout Grid.Column="1" Spacing="6">
                                        <Label Text="CVV"
                                           FontSize="13" TextColor="#666666" />
                                        <Border BackgroundColor="#F8F6F3"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="#E0D8D0">
                                            <Entry x:Name="CvvEntry"
                                               Placeholder="•••"
                                               PlaceholderColor="#BBBBBB"
                                               TextColor="#1A1A1A"
                                               FontSize="15"
                                               IsPassword="True"
                                               Keyboard="Numeric"
                                               MaxLength="4"
                                               BackgroundColor="Transparent"
                                               Margin="4,0" />
                                        </Border>
                                    </StackLayout>
                                </Grid>
                            </StackLayout>

                        </StackLayout>
                    </Border>

                </StackLayout>
            </ScrollView>

            <!-- ── Pay CTA ──────────────────────────────────────────── -->
            <Border Grid.Row="2"
                BackgroundColor="White"
                Stroke="Transparent"
                Padding="20,12">
                <Button x:Name="PayBtn"
                    BackgroundColor="#C8683A"
                    TextColor="White"
                    FontSize="17"
                    FontAttributes="Bold"
                    HeightRequest="54"
                    CornerRadius="14"
                    Clicked="OnPayClicked" />
            </Border>

        </Grid>
    </VerticalStackLayout>
</ContentPage>