<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.Pages.CartPage"
             Title="CartPage">
	<VerticalStackLayout>
		<Grid RowDefinitions="Auto,*,Auto">

			<!-- ── Header ───────────────────────────────────────────── -->
			<Grid Grid.Row="0" Padding="20,16" ColumnDefinitions="Auto,*"
              BackgroundColor="#F5F0EB">
				<ImageButton Grid.Column="0"
                         Source="icon_back.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#EBEBEB"
                         CornerRadius="18"
                         Clicked="OnBackClicked" />
				<Label Grid.Column="1" Text="My Cart"
                   FontSize="20" FontAttributes="Bold" TextColor="#1A1A1A"
                   HorizontalOptions="Center" VerticalOptions="Center" />
			</Grid>

			<!-- ── Cart Items ────────────────────────────────────────── -->
			<ScrollView Grid.Row="1" Padding="16,0">
				<StackLayout Spacing="12">

					<CollectionView x:Name="CartCollection" SelectionMode="None">
						<CollectionView.ItemTemplate>
							<DataTemplate>
								<Border BackgroundColor="White"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="Transparent"
                                    Padding="14" Margin="0,0,0,10"
                                    Shadow="{Shadow Brush='#18000000', Offset='0,2', Radius='6'}">
									<Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="14">

										<Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="Transparent"
                                            BackgroundColor="#F0EBE5"
                                            WidthRequest="72" HeightRequest="72">
											<Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               WidthRequest="72" HeightRequest="72" />
										</Border>

										<StackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
											<Label Text="{Binding Name}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#1A1A1A"
                                               LineBreakMode="TailTruncation" />
											<!-- Variant shown only if not empty -->
											<Label Text="{Binding Variant}"
                                               FontSize="12" TextColor="#9E9E9E" />
											<Label Text="{Binding FormattedUnitPrice}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#C8683A" />
										</StackLayout>

										<StackLayout Grid.Column="2" Spacing="8"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="End">
											<HorizontalStackLayout Spacing="8">
												<Border BackgroundColor="#F0EBE5"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="Transparent">
													<Button Text="−"
                                                        WidthRequest="32" HeightRequest="32"
                                                        FontSize="16" Padding="0"
                                                        BackgroundColor="Transparent"
                                                        TextColor="#1A1A1A"
                                                        CommandParameter="{Binding .}"
                                                        Clicked="OnDecreaseQty" />
												</Border>
												<Label Text="{Binding Quantity}"
                                                   WidthRequest="22" FontSize="15"
                                                   FontAttributes="Bold"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalOptions="Center"
                                                   TextColor="#1A1A1A" />
												<Border BackgroundColor="#F0EBE5"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="Transparent">
													<Button Text="+"
                                                        WidthRequest="32" HeightRequest="32"
                                                        FontSize="16" Padding="0"
                                                        BackgroundColor="Transparent"
                                                        TextColor="#C8683A"
                                                        CommandParameter="{Binding .}"
                                                        Clicked="OnIncreaseQty" />
												</Border>
											</HorizontalStackLayout>
											<Button Text="Remove"
                                                FontSize="11" TextColor="#C8683A"
                                                BackgroundColor="Transparent" Padding="0"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnRemoveItem" />
										</StackLayout>
									</Grid>
								</Border>
							</DataTemplate>
						</CollectionView.ItemTemplate>
					</CollectionView>

					<!-- Order summary card -->
					<Border x:Name="SummaryCard"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16"
                        Stroke="Transparent"
                        Padding="18" Margin="0,4,0,16"
                        Shadow="{Shadow Brush='#18000000', Offset='0,2', Radius='6'}">
						<StackLayout Spacing="10">
							<Grid ColumnDefinitions="*,Auto">
								<Label Grid.Column="0" Text="Subtotal"
                                   FontSize="14" TextColor="#666666" />
								<Label Grid.Column="1" x:Name="SubtotalLabel"
                                   FontSize="14" TextColor="#1A1A1A"
                                   FontAttributes="Bold" HorizontalOptions="End" />
							</Grid>
							<Grid ColumnDefinitions="*,Auto">
								<Label Grid.Column="0" Text="Shipping"
                                   FontSize="14" TextColor="#666666" />
								<Label Grid.Column="1" Text="Free"
                                   FontSize="14" TextColor="#4A7C59"
                                   FontAttributes="Bold" HorizontalOptions="End" />
							</Grid>
							<BoxView HeightRequest="1" BackgroundColor="#F0EBE5" />
							<Grid ColumnDefinitions="*,Auto">
								<Label Grid.Column="0" Text="Total"
                                   FontSize="16" FontAttributes="Bold" TextColor="#1A1A1A" />
								<Label Grid.Column="1" x:Name="TotalLabel"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#1A1A1A" HorizontalOptions="End" />
							</Grid>
						</StackLayout>
					</Border>
				</StackLayout>
			</ScrollView>

			<!-- ── Checkout Button ──────────────────────────────────── -->
			<Border Grid.Row="2" BackgroundColor="White"
                StrokeShape="RoundRectangle 0" Stroke="Transparent" Padding="20,12">
				<Button x:Name="CheckoutBtn"
                    Text="Proceed to checkout"
                    BackgroundColor="#C8683A" TextColor="White"
                    FontSize="17" FontAttributes="Bold"
                    HeightRequest="54" CornerRadius="14"
                    Clicked="OnCheckoutClicked" />
			</Border>
		</Grid>
	</VerticalStackLayout>

</ContentPage>