<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.ResetPassword"
             Title="ResetPassword">
    <ScrollView>
        <VerticalStackLayout Padding="28,60,28,40" Spacing="0">

            <!-- Icon -->
            <Border BackgroundColor="#FDF0EA"
                    StrokeShape="RoundRectangle 22"
                    Stroke="Transparent"
                    WidthRequest="72"
                    HeightRequest="72"
                    HorizontalOptions="Center"
                    Margin="0,0,0,24">
                <Label Text="🔑"
                       FontSize="32"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- Heading -->
            <Label Text="Forgot Password"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8" />
            <Label Text="Enter your email and we'll send you a reset link"
                   FontSize="14"
                   TextColor="#9E9E9E"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,36" />

            <!-- Form card -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="24"
                    Shadow="{Shadow Brush='#20000000', Offset='0,4', Radius='12'}">
                <StackLayout Spacing="18">

                    <!-- Email -->
                    <StackLayout Spacing="6">
                        <Label Text="Email address"
                               FontSize="13"
                               TextColor="#666666" />
                        <Border BackgroundColor="#F8F6F3"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#E0D8D0">
                            <Entry x:Name="EmailEntry"
                                   Placeholder="you@example.com"
                                   PlaceholderColor="#BBBBBB"
                                   TextColor="#1A1A1A"
                                   FontSize="15"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"
                                   Margin="8,2" />
                        </Border>
                    </StackLayout>

                    <!-- Error label -->
                    <Label x:Name="ErrorLabel"
                           TextColor="#C8683A"
                           FontSize="13"
                           IsVisible="False"
                           HorizontalOptions="Center" />

                    <!-- Success label -->
                    <Label x:Name="SuccessLabel"
                           TextColor="#4A7C59"
                           FontSize="13"
                           IsVisible="False"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center" />

                    <!-- Send button -->
                    <Button x:Name="SendBtn"
                            Text="Send reset link"
                            BackgroundColor="#C8683A"
                            TextColor="White"
                            FontSize="17"
                            FontAttributes="Bold"
                            HeightRequest="54"
                            CornerRadius="14"
                            Margin="0,6,0,0"
                            Clicked="OnSendClicked" />

                </StackLayout>
            </Border>

            <!-- Back to sign in -->
            <HorizontalStackLayout HorizontalOptions="Center"
                                   Margin="0,28,0,0"
                                   Spacing="4">
                <Label Text="←" FontSize="14" TextColor="#BBBBBB" />
                <Label Text="Back to sign in"
                       FontSize="14"
                       TextColor="#BBBBBB">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
