<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.AdminPages.AdminOrdersPage"
             Title="AdminOrdersPage">
    <VerticalStackLayout>
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- ── Header ───────────────────────────────────────────── -->
            <Grid Grid.Row="0"
           BackgroundColor="#1A1A1A"
           Padding="20,52,20,20"
           ColumnDefinitions="Auto,*,Auto">
                <ImageButton Grid.Column="0"
                      Source="icon_back_white.png"
                      WidthRequest="36" HeightRequest="36"
                      BackgroundColor="#333333"
                      CornerRadius="18"
                      Clicked="OnBackClicked" />
                <StackLayout Grid.Column="1" Spacing="2"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                    <Label Text="ADMIN" FontSize="11"
                    TextColor="#AAAAAA" CharacterSpacing="3"
                    HorizontalOptions="Center" />
                    <Label Text="Orders" FontSize="20"
                    FontAttributes="Bold" TextColor="White"
                    HorizontalOptions="Center" />
                </StackLayout>
                <Border Grid.Column="2"
                 BackgroundColor="#333333"
                 StrokeShape="RoundRectangle 10"
                 Stroke="Transparent"
                 Padding="10,6">
                    <Label x:Name="TotalOrdersLabel"
                    Text="0 total"
                    FontSize="13"
                    TextColor="White" />
                </Border>
            </Grid>

            <!-- ── Filter tabs ──────────────────────────────────────── -->
            <ScrollView Grid.Row="1"
                 Orientation="Horizontal"
                 HorizontalScrollBarVisibility="Never"
                 Padding="16,12,16,4">
                <HorizontalStackLayout Spacing="8">
                    <Border x:Name="TabAll"
                     BackgroundColor="#1A1A1A"
                     StrokeShape="RoundRectangle 20"
                     Stroke="Transparent"
                     Padding="18,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterAll" />
                        </Border.GestureRecognizers>
                        <Label Text="All" FontSize="14"
                        FontAttributes="Bold" TextColor="White" />
                    </Border>
                    <Border x:Name="TabPending"
                     BackgroundColor="White"
                     StrokeShape="RoundRectangle 20"
                     Stroke="#E0D8D0"
                     Padding="18,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterPending" />
                        </Border.GestureRecognizers>
                        <Label Text="Pending" FontSize="14" TextColor="#666666" />
                    </Border>
                    <Border x:Name="TabShipped"
                     BackgroundColor="White"
                     StrokeShape="RoundRectangle 20"
                     Stroke="#E0D8D0"
                     Padding="18,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterShipped" />
                        </Border.GestureRecognizers>
                        <Label Text="Shipped" FontSize="14" TextColor="#666666" />
                    </Border>
                    <Border x:Name="TabDelivered"
                     BackgroundColor="White"
                     StrokeShape="RoundRectangle 20"
                     Stroke="#E0D8D0"
                     Padding="18,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterDelivered" />
                        </Border.GestureRecognizers>
                        <Label Text="Delivered" FontSize="14" TextColor="#666666" />
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- ── Orders list ──────────────────────────────────────── -->
            <RefreshView Grid.Row="2"
                  x:Name="RefreshControl"
                  IsRefreshing="{Binding IsRefreshing}"
                  RefreshColor="#C8683A"
                  Refreshed="OnRefreshed">
                <CollectionView x:Name="OrdersCollection"
                         SelectionMode="None"
                         Margin="16,8,16,16">

                    <CollectionView.EmptyView>
                        <StackLayout VerticalOptions="Center"
                              HorizontalOptions="Center"
                              Padding="40" Spacing="10">
                            <Label Text="📋" FontSize="40"
                            HorizontalOptions="Center" />
                            <Label Text="No orders found"
                            FontSize="16" TextColor="#9E9E9E"
                            HorizontalOptions="Center" />
                        </StackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                             StrokeShape="RoundRectangle 14"
                             Stroke="Transparent"
                             Margin="0,0,0,10"
                             Shadow="{Shadow Brush='#15000000', Offset='0,2', Radius='6'}"
                             Padding="16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding .}"
                                                   Tapped="OnOrderTapped" />
                                </Border.GestureRecognizers>
                                <StackLayout Spacing="10">

                                    <!-- Top row: OrderId + Status badge -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                        Text="{Binding OrderId}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="#1A1A1A" />

                                        <!-- Status badge - color changes by status -->
                                        <Border Grid.Column="1"
                                         x:Name="StatusBadge"
                                         StrokeShape="RoundRectangle 8"
                                         Stroke="Transparent"
                                         Padding="10,4">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                      Binding="{Binding Status}"
                                                      Value="Pending">
                                                    <Setter Property="BackgroundColor" Value="#FFF3E0" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border"
                                                      Binding="{Binding Status}"
                                                      Value="Shipped">
                                                    <Setter Property="BackgroundColor" Value="#E8F0FE" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border"
                                                      Binding="{Binding Status}"
                                                      Value="Delivered">
                                                    <Setter Property="BackgroundColor" Value="#EEF5F0" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Status}"
                                            FontSize="12"
                                            FontAttributes="Bold">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                          Binding="{Binding Status}"
                                                          Value="Pending">
                                                        <Setter Property="TextColor" Value="#E67E22" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label"
                                                          Binding="{Binding Status}"
                                                          Value="Shipped">
                                                        <Setter Property="TextColor" Value="#2E6DA4" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label"
                                                          Binding="{Binding Status}"
                                                          Value="Delivered">
                                                        <Setter Property="TextColor" Value="#4A7C59" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                    </Grid>

                                    <!-- Customer + Date -->
                                    <Label Text="{Binding CustomerName}"
                                    FontSize="14"
                                    TextColor="#444444" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                        FontSize="12"
                                        TextColor="#9E9E9E">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} · {1} items">
                                                    <Binding Path="FormattedDate" />
                                                    <Binding Path="ItemCount" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <HorizontalStackLayout Grid.Column="1" Spacing="6">
                                            <Label Text="{Binding FormattedTotal}"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            TextColor="#C8683A"
                                            VerticalOptions="Center" />
                                            <Label Text="View →"
                                            FontSize="13"
                                            TextColor="#C8683A"
                                            VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Grid>

                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- Loading -->
            <ActivityIndicator Grid.Row="2"
                        x:Name="LoadingIndicator"
                        IsRunning="True"
                        IsVisible="True"
                        Color="#C8683A"
                        VerticalOptions="Center"
                        HorizontalOptions="Center" />

        </Grid>
    </VerticalStackLayout>
</ContentPage>