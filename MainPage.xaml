<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label Text="Welcome"
                   FontSize="28"
                   HorizontalOptions="Center" />

            <Button Text="Sign In "
                    Clicked="OnSignInClicked" />
            <Button Text="Sign Up "
        Clicked="OnSignUpClicked" />

            <Label Text="Admin access"
                   FontSize="13"
                   TextColor="#BBBBBB"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAdminTapped" />
                </Label.GestureRecognizers>
            </Label>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
