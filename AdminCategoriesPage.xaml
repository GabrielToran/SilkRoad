<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.AdminPages.AdminCategoriesPage"
             Title="AdminCategoriesPage">
    <VerticalStackLayout>
        <Grid RowDefinitions="Auto,*">

            <!-- ── Header ───────────────────────────────────────────── -->
            <Grid Grid.Row="0"
              BackgroundColor="#1A1A1A"
              Padding="20,52,20,20"
              ColumnDefinitions="Auto,*,Auto">
                <ImageButton Grid.Column="0"
                         Source="icon_back_white.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#333333"
                         CornerRadius="18"
                         Clicked="OnBackClicked" />
                <StackLayout Grid.Column="1" Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
                    <Label Text="ADMIN" FontSize="11"
                       TextColor="#AAAAAA" CharacterSpacing="3"
                       HorizontalOptions="Center" />
                    <Label Text="Categories" FontSize="20"
                       FontAttributes="Bold" TextColor="White"
                       HorizontalOptions="Center" />
                </StackLayout>
                <Button Grid.Column="2"
                    Text="+ Add"
                    BackgroundColor="#C8683A"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    CornerRadius="10"
                    Padding="14,0"
                    Clicked="OnAddCategoryClicked" />
            </Grid>

            <!-- ── Categories list ──────────────────────────────────── -->
            <RefreshView Grid.Row="1"
                     x:Name="RefreshControl"
                     IsRefreshing="{Binding IsRefreshing}"
                     RefreshColor="#C8683A"
                     Refreshed="OnRefreshed">
                <CollectionView x:Name="CategoriesCollection"
                            SelectionMode="None"
                            Margin="16,12,16,16">

                    <CollectionView.EmptyView>
                        <StackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Padding="40" Spacing="10">
                            <Label Text="🗂️" FontSize="40"
                               HorizontalOptions="Center" />
                            <Label Text="No categories yet"
                               FontSize="16" TextColor="#9E9E9E"
                               HorizontalOptions="Center" />
                        </StackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White"
                                StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                Margin="0,0,0,10"
                                Shadow="{Shadow Brush='#15000000', Offset='0,2', Radius='6'}">
                                <Grid ColumnDefinitions="56,*,Auto,Auto"
                                  ColumnSpacing="12"
                                  Padding="14">

                                    <!-- Icon placeholder -->
                                    <Border Grid.Column="0"
                                        BackgroundColor="#FDF0EA"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="Transparent"
                                        WidthRequest="48"
                                        HeightRequest="48">
                                        <Label Text="🏷️"
                                           FontSize="22"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                    </Border>

                                    <!-- Name + count -->
                                    <StackLayout Grid.Column="1"
                                             Spacing="4"
                                             VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#1A1A1A" />
                                        <Label FontSize="12" TextColor="#888888">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} products">
                                                    <Binding Path="ProductCount" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </StackLayout>

                                    <!-- Edit button -->
                                    <Border Grid.Column="2"
                                        BackgroundColor="#F0EBE5"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        WidthRequest="38" HeightRequest="38"
                                        VerticalOptions="Center">
                                        <ImageButton Source="icon_edit.png"
                                                 WidthRequest="18" HeightRequest="18"
                                                 BackgroundColor="Transparent"
                                                 CommandParameter="{Binding .}"
                                                 Clicked="OnEditCategoryClicked" />
                                    </Border>

                                    <!-- Delete button -->
                                    <Border Grid.Column="3"
                                        BackgroundColor="#FAEAEA"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        WidthRequest="38" HeightRequest="38"
                                        VerticalOptions="Center">
                                        <ImageButton Source="icon_delete.png"
                                                 WidthRequest="18" HeightRequest="18"
                                                 BackgroundColor="Transparent"
                                                 CommandParameter="{Binding .}"
                                                 Clicked="OnDeleteCategoryClicked" />
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- Loading -->
            <ActivityIndicator Grid.Row="1"
                           x:Name="LoadingIndicator"
                           IsRunning="True"
                           IsVisible="True"
                           Color="#C8683A"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        </Grid>
    </VerticalStackLayout>
</ContentPage>