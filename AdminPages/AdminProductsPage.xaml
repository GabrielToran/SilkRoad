<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Multiplatoform_Project.AdminPages.AdminProductsPage">
	<VerticalStackLayout>
		<Grid RowDefinitions="Auto,Auto,*">

			<!-- ── Header ───────────────────────────────────────────── -->
			<Grid Grid.Row="0"
              BackgroundColor="#1A1A1A"
              Padding="20,52,20,20"
              ColumnDefinitions="Auto,*,Auto">
				<ImageButton Grid.Column="0"
                         Source="icon_back_white.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="#333333"
                         CornerRadius="18"
                         Clicked="OnBackClicked" />
				<StackLayout Grid.Column="1" Spacing="2"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">
					<Label Text="ADMIN" FontSize="11"
                       TextColor="#AAAAAA" CharacterSpacing="3"
                       HorizontalOptions="Center" />
					<Label Text="Products" FontSize="20"
                       FontAttributes="Bold" TextColor="White"
                       HorizontalOptions="Center" />
				</StackLayout>
				<Button Grid.Column="2"
                    Text="+ Add"
                    BackgroundColor="#C8683A"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    CornerRadius="10"
                    Padding="14,0"
                    Clicked="OnAddProductClicked" />
			</Grid>

			<!-- ── Search bar ───────────────────────────────────────── -->
			<Border Grid.Row="1"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 12"
                Stroke="#E0D8D0"
                Margin="16,12,16,4">
				<Grid ColumnDefinitions="Auto,*">
					<Label Grid.Column="0"
                       Text="🔍"
                       FontSize="16"
                       VerticalOptions="Center"
                       Margin="12,0,4,0" />
					<Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       Placeholder="Search products..."
                       PlaceholderColor="#BBBBBB"
                       TextColor="#1A1A1A"
                       FontSize="15"
                       BackgroundColor="Transparent"
                       TextChanged="OnSearchTextChanged"
                       Margin="0,2" />
				</Grid>
			</Border>

			<!-- ── Products list ────────────────────────────────────── -->
			<RefreshView Grid.Row="2"
                     x:Name="RefreshControl"
                     IsRefreshing="{Binding IsRefreshing}"
                     RefreshColor="#C8683A"
                     Command="{Binding RefreshCommand}">
				<CollectionView x:Name="ProductsCollection"
                            SelectionMode="None"
                            Margin="16,8,16,16">

					<CollectionView.EmptyView>
						<StackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Padding="40" Spacing="10">
							<Label Text="📦" FontSize="40"
                               HorizontalOptions="Center" />
							<Label Text="No products found"
                               FontSize="16" TextColor="#9E9E9E"
                               HorizontalOptions="Center" />
						</StackLayout>
					</CollectionView.EmptyView>

					<CollectionView.ItemTemplate>
						<DataTemplate>
							<Border BackgroundColor="White"
                                StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                Margin="0,0,0,10"
                                Shadow="{Shadow Brush='#15000000', Offset='0,2', Radius='6'}">
								<Grid ColumnDefinitions="64,*,Auto,Auto"
                                  ColumnSpacing="12"
                                  Padding="12">

									<!-- Color swatch / image thumbnail -->
									<Border Grid.Column="0"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        BackgroundColor="#E8E0D8"
                                        WidthRequest="64"
                                        HeightRequest="64">
										<Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           WidthRequest="64"
                                           HeightRequest="64" />
									</Border>

									<!-- Info -->
									<StackLayout Grid.Column="1"
                                             Spacing="4"
                                             VerticalOptions="Center">
										<Label Text="{Binding Name}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#1A1A1A"
                                           LineBreakMode="TailTruncation" />
										<HorizontalStackLayout Spacing="6">
											<Label Text="{Binding CategoryName}"
                                               FontSize="12"
                                               TextColor="#888888" />
											<Label Text="·" FontSize="12" TextColor="#CCCCCC" />
											<Label Text="{Binding FormattedPrice}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="#C8683A" />
										</HorizontalStackLayout>

										<!-- Availability badge -->
										<Border StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent"
                                            Padding="8,3"
                                            HorizontalOptions="Start">
											<Border.Triggers>
												<DataTrigger TargetType="Border"
                                                         Binding="{Binding Available}"
                                                         Value="True">
													<Setter Property="BackgroundColor" Value="#EEF5F0" />
												</DataTrigger>
												<DataTrigger TargetType="Border"
                                                         Binding="{Binding Available}"
                                                         Value="False">
													<Setter Property="BackgroundColor" Value="#F9ECEA" />
												</DataTrigger>
											</Border.Triggers>
											<Label FontSize="11" FontAttributes="Bold">
												<Label.Triggers>
													<DataTrigger TargetType="Label"
                                                             Binding="{Binding Available}"
                                                             Value="True">
														<Setter Property="Text" Value="Available" />
														<Setter Property="TextColor" Value="#4A7C59" />
													</DataTrigger>
													<DataTrigger TargetType="Label"
                                                             Binding="{Binding Available}"
                                                             Value="False">
														<Setter Property="Text" Value="Unavailable" />
														<Setter Property="TextColor" Value="#C0392B" />
													</DataTrigger>
												</Label.Triggers>
											</Label>
										</Border>
									</StackLayout>

									<!-- Edit button -->
									<Border Grid.Column="2"
                                        BackgroundColor="#F0EBE5"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        WidthRequest="38" HeightRequest="38"
                                        VerticalOptions="Center">
										<ImageButton Source="icon_edit.png"
                                                 WidthRequest="18" HeightRequest="18"
                                                 BackgroundColor="Transparent"
                                                 CommandParameter="{Binding .}"
                                                 Clicked="OnEditProductClicked" />
									</Border>

									<!-- Delete button -->
									<Border Grid.Column="3"
                                        BackgroundColor="#FAEAEA"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        WidthRequest="38" HeightRequest="38"
                                        VerticalOptions="Center">
										<ImageButton Source="icon_delete.png"
                                                 WidthRequest="18" HeightRequest="18"
                                                 BackgroundColor="Transparent"
                                                 CommandParameter="{Binding .}"
                                                 Clicked="OnDeleteProductClicked" />
									</Border>

								</Grid>
							</Border>
						</DataTemplate>
					</CollectionView.ItemTemplate>
				</CollectionView>
			</RefreshView>

			<!-- Loading overlay -->
			<ActivityIndicator Grid.Row="2"
                           x:Name="LoadingIndicator"
                           IsRunning="True"
                           IsVisible="True"
                           Color="#C8683A"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

		</Grid>
	</VerticalStackLayout>
</ContentPage>
